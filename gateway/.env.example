# esp-gateway configuration — copy to .env (or set in the environment / compose).
# Secrets are read from the environment and never written to disk by the gateway.

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8770

# Butler brain. On the homeserver Docker network use the service name; for local
# dev against the Mac Mini use the LAN IP.
BUTLER_API_URL=http://butler-api:8000
INTERNAL_API_KEY=__same_as_butler_env__

# Kokoro TTS
KOKORO_URL=http://kokoro-tts:8880
KOKORO_VOICE=bf_emma

# Groq STT — same key as voice-stack/.env. If unset, only the typed-text path works
# (spoken audio yields no transcript).
GROQ_API_KEY=

# Device auth: map device tokens -> allowed butler user_ids. [] means "any user".
# Preferred JSON form:
GATEWAY_DEVICE_TOKENS={"CHANGE-ME-TOKEN":["invite_butler_001"]}
# ...or the single-token form:
# GATEWAY_DEVICE_TOKEN=CHANGE-ME-TOKEN
# GATEWAY_ALLOWED_USERS=invite_butler_001,invite_butler_002

# Local dev only: accept any device token when none are configured.
# GATEWAY_ALLOW_INSECURE=1
